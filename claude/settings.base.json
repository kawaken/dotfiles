{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(sleep:*)",
      "Bash(history:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(jq:*)",
      "Bash(npm view:*)",
      "Read(./**)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh ssh-key delete:*)",
      "Bash(gh gpg-key delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release delete-asset:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh gist delete:*)",
      "Bash(gh org remove-member:*)",
      "Bash(gh repo remove-collaborator:*)",
      "Bash(gh variable delete:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/validate-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/validate-general.sh"
          },
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/validate-cd-git.sh"
          },
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/validate-rails.sh"
          },
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/validate-tool-use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/retro-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/dotfiles/claude/statusline.sh"
  },
  "language": "Japanese"
}
